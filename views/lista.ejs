<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Lista de Mensagens</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h1 class="mb-4">Mensagens Recebidas</h1>

    <div class="list-group">
        <% if (lista.length > 0) { %>
            <% lista.forEach(function(item) { %>
                <div class="list-group-item shadow-sm mb-2">
                    <h5>Nome: <%= item.nome %></h5>
                    <p>Mensagem: <%= item.mensagem %></p>
                </div>
            <% }); %>
        <% } else { %>
            <div class="alert alert-warning">Nenhum dado encontrado no arquivo.</div>
        <% } %>
    </div>

    <hr>
    <a href="/contato" class="btn btn-primary">Voltar ao Formulário</a>
</body>
</html>